name: "RFDETR_SEG_PRE_POSTPROCESS"
backend: "rfdetr_seg_postprocess"
max_batch_size: 16

# RF-DETR seg 后处理：
#   - dets:   [batch, 100, 4]  归一化 cxcywh 框
#   - labels: [batch, 100, 91] 类别 logits（dim 0 为背景，dim 1..90 对应 COCO ID 1~90）
#   - masks:  [batch, 100, 96, 96] mask logits
#   - transform_metadata: [batch, 6] 预处理逆变换矩阵（d2i）

input [
  {
    name: "dets"
    data_type: TYPE_FP32
    dims: [100, 4]
  },
  {
    name: "labels"
    data_type: TYPE_FP32
    dims: [100, 91]
  },
  {
    name: "masks"
    data_type: TYPE_FP32
    dims: [100, -1, -1]
  },
  {
    name: "transform_metadata"
    data_type: TYPE_FP32
    dims: [6]
  }
]

output [
  {
    name: "num_dets"
    data_type: TYPE_INT32
    dims: [1]
  },
  {
    name: "detection_boxes"
    data_type: TYPE_FP32
    dims: [-1, 4]
  },
  {
    name: "detection_scores"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "detection_classes"
    data_type: TYPE_INT32
    dims: [-1]
  },
  {
    name: "detection_masks"
    data_type: TYPE_FP32
    dims: [-1, -1]
  },
  {
    name: "mask_shapes"
    data_type: TYPE_INT32
    dims: [-1, 2]
  }
]

parameters: {
  key: "confidence_threshold"
  value: { string_value: "0.25" }
}
parameters: {
  key: "max_detections"
  value: { string_value: "100" }
}
parameters: {
  key: "num_queries"
  value: { string_value: "100" }
}
parameters: {
  key: "input_width"
  value: { string_value: "384" }
}
parameters: {
  key: "input_height"
  value: { string_value: "384" }
}
parameters: {
  key: "return_masks"
  value: { string_value: "true" }
}
parameters: {
  key: "skip_coco_ids"
  value: { string_value: "[12, 26, 29, 30, 45, 66, 68, 69, 71, 83]" }
}

instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
