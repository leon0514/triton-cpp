name: "yolov5_postprocess"
backend: "yolov5_postprocess"
max_batch_size: 16

# YOLOv5 经典导出格式（yolov5 仓库 export.py）：
#   - anchor_first:   [batch, 25200, 85]  （4 box + 1 obj_conf + 80 class）
#   - channel_first:  [batch, 85, 25200]
# 这里以 anchor_first 为例，对应 output_format="anchor_first"。

input [
  {
    name: "model_output"
    data_type: TYPE_FP32
    dims: [25200, 85]
  }
]

output [
  {
    name: "num_dets"
    data_type: TYPE_INT32
    dims: [1]
  },
  {
    name: "detection_boxes"
    data_type: TYPE_FP32
    dims: [-1, 4]
  },
  {
    name: "detection_scores"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "detection_classes"
    data_type: TYPE_INT32
    dims: [-1]
  }
]

parameters: {
  key: "num_classes"
  value: { string_value: "80" }
}
parameters: {
  key: "confidence_threshold"
  value: { string_value: "0.25" }
}
parameters: {
  key: "iou_threshold"
  value: { string_value: "0.45" }
}
parameters: {
  key: "max_detections"
  value: { string_value: "300" }
}
parameters: {
  key: "max_candidates"
  value: { string_value: "25200" }
}
parameters: {
  key: "output_format"
  value: { string_value: "anchor_first" }
}
parameters: {
  key: "score_activation"
  value: { string_value: "none" }
}
parameters: {
  key: "has_objectness"
  value: { string_value: "true" }
}

instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
