name: "rfdetr_seg"
platform: "tensorrt_plan"
max_batch_size: 16
default_model_filename: "model.plan"

input [
  {
    name: "input"
    data_type: TYPE_FP32
    dims: [3, 384, 384]
  }
]

output [
  {
    name: "dets"
    data_type: TYPE_FP32
    # [batch, 100, 4] 归一化 cxcywh
    dims: [100, 4]
  },
  {
    name: "labels"
    data_type: TYPE_FP32
    # [batch, 100, 91] logits（dim 0 为背景，dim 1..90 对应 COCO ID 1~90）
    dims: [100, 91]
  },
  {
    name: "masks"
    data_type: TYPE_FP32
    # [batch, 100, 96, 96] mask logits
    dims: [100, 96, 96]
  }
]

instance_group [
  { count: 1, kind: KIND_GPU, gpus: [0] }
]
